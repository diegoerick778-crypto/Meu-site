import tkinter as tk
def clicar():
janela = tk.Tk()
janela.title("Minha primeira GUI")
janela.geometry("300x200")
label = tk.Label(janela, text="Olá, mundo!")
label.pack(pady=10)
botao = tk.Button(janela, text="Clique aqui", command=clicar)
botao.pack(pady=10)
janela.mainloop()
print("hello world")
